From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Sun, 14 Jun 2026 16:00:00 +0800
Subject: [PATCH] build/script: print sccache stats alongside ccache

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/script/run-make.sh | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/script/run-make.sh b/src/script/run-make.sh
index 30ca35ce274..833fe77f8e6 100755
--- a/src/script/run-make.sh
+++ b/src/script/run-make.sh
@@ -190,6 +190,11 @@ function build() {
     ci_debug "Running cmake"
     $DRY_RUN cmake --build . $targets -- $BUILD_MAKEOPTS || return 1
     $DRY_RUN ccache -s # print the ccache statistics to evaluate the efficiency
+    # sccache is the real compiler launcher under WITH_SCCACHE; print its
+    # hit/miss stats too so CI can gauge the cross-run cache, not just ccache's.
+    if type sccache > /dev/null 2>&1; then
+        $DRY_RUN sccache --show-stats
+    fi
 }
 
 DEFAULT_MAKEOPTS=${DEFAULT_MAKEOPTS:--j$(get_processors)}
-- 
2.54.0

