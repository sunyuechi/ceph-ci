---
 src/test/smoke.sh | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/test/smoke.sh b/src/test/smoke.sh
index b66266e6bf6..5b1d3fdaa65 100755
--- a/src/test/smoke.sh
+++ b/src/test/smoke.sh
@@ -53,7 +53,7 @@ function TEST_multimon() {
     ceph osd out 0
     wait_for_clean
 
-    timeout 20 rados -p foo bench 4 write -b 4096 --no-cleanup || return 1
+    timeout 120 rados -p foo bench 4 write -b 4096 --no-cleanup || return 1
     wait_for_clean
 
     ceph osd in 0
