From 6d943d50acb8fc131096f3c2c0062705ddb75567 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Mon, 29 Jun 2026 19:37:09 -0700
Subject: [PATCH 02/13] rgw/keystone: guard against empty secret file in
 read_secret

After trimming, an empty or all-whitespace secret file leaves s empty,
and s.back() is then undefined behavior. trim() already strips trailing
newlines, so guard the back()/pop_back() with an emptiness check.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/rgw/rgw_keystone.cc | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/rgw/rgw_keystone.cc b/src/rgw/rgw_keystone.cc
index bdfa848b6c0..f37ef105c6b 100644
--- a/src/rgw/rgw_keystone.cc
+++ b/src/rgw/rgw_keystone.cc
@@ -89,7 +89,7 @@ static inline std::string read_secret(const std::string& file_path)
       s.append(buf, len);
     }
     boost::algorithm::trim(s);
-    if (s.back() == '\n')
+    if (!s.empty() && s.back() == '\n')
       s.pop_back();
   }
   return s;
-- 
