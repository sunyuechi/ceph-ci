-    return clone.encryption_load(RBD_ENCRYPTION_FORMAT_LUKS, &opts,
-                                 sizeof(opts));
-  }
-
-  int load_flattened(librbd::Image& clone) {
-    return load(clone);
-  }
-
-  std::string m_passphrase = "some passphrase";
-};
