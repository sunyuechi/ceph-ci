+    ASSERT_EQ(0, TestEncryption::format(ictx, RBD_ENCRYPTION_FORMAT_LUKS1,
+                                        &fopts, sizeof(fopts)));
+
+    // after loading encryption on the clone, one can get rid of
+    // unneeded space allowance in the clone arising from LUKS2 header
