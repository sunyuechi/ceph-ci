+
+  for (auto& specs : good_specs) {
+    ASSERT_EQ(0, open_image(name3, &ictx));
+    ASSERT_EQ(0, load(ictx, specs.data(), specs.size()));
+    close_image(ictx);
+  }
+
+  ASSERT_EQ(0, open_image(name3, &ictx));
+  for (auto& specs : bad_specs) {
