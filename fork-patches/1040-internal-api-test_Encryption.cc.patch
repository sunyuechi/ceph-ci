+struct LUKS1UnderLUKS2 : LUKSTwoPassphrases {
+  void setup_parent(librbd::ImageCtx* ictx, uint64_t data_size) {
+    uint64_t luks1_meta_size = 4 << 20;
+    ASSERT_EQ(0, TestEncryption::resize(ictx, data_size + luks1_meta_size));
