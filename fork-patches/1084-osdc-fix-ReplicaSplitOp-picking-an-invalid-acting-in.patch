From 0b9e84a9d314c5a5fd348b41972dee03e4883ce3 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Wed, 1 Jul 2026 01:57:10 -0700
Subject: [PATCH] osdc: fix ReplicaSplitOp picking an invalid acting index

init_reference_sub_read() counted the existing OSDs in the acting set
and then used "rand() % valid_osd_count" as an acting index. When the
acting set is degraded and contains holes, the count is not a valid
index space: an index below the count may point at a missing OSD while
valid indices sit beyond it. reference_sub_read is later used as an
acting index, so this could target a non-existent OSD.

Collect the indices of existing OSDs and pick one of those at random,
matching how ECSplitOp stores an actual acting index.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/osdc/SplitOp.cc | 16 +++++++++-------
 1 file changed, 9 insertions(+), 7 deletions(-)

diff --git a/src/osdc/SplitOp.cc b/src/osdc/SplitOp.cc
index 7fbc6559544..6314e9ba3fe 100644
--- a/src/osdc/SplitOp.cc
+++ b/src/osdc/SplitOp.cc
@@ -255,23 +255,25 @@ void ECSplitOp::init_read(OSDOp &op, bool sparse, int ops_index) {
 void ReplicaSplitOp::init_reference_sub_read() {
   auto &target = orig_op->target;
   
-  // Count valid OSDs in the acting set
-  int valid_osd_count = 0;
+  // Collect the acting indices that map to an existing OSD. The acting
+  // set may contain holes (missing OSDs) when degraded, so we must track
+  // the indices themselves rather than just a count.
+  std::vector<int> valid_indices;
   for (size_t i = 0; i < target.acting.size(); i++) {
     int direct_osd = target.acting[i];
     if (objecter.osdmap->exists(direct_osd)) {
-      valid_osd_count++;
+      valid_indices.push_back(i);
     }
   }
-  
-  if (valid_osd_count < 2) {
+
+  if (valid_indices.size() < 2) {
     abort = true;
     ldout(cct, DBG_LVL) << __func__ << " ABORT: Not enough valid OSDs" << dendl;
     return;
   }
-  
+
   // Pick a random valid acting index
-  reference_sub_read = rand() % valid_osd_count;
+  reference_sub_read = valid_indices[rand() % valid_indices.size()];
 }
 
