From b7fa1ad148bede54ba0bdcedcec32ba1a4ff2039 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Wed, 1 Jul 2026 02:59:15 -0700
Subject: [PATCH 10/10] cephfs bench: fix invalid short option name for
 --filesystem

Boost.Program_options requires the short name after the comma to be
a single character, but the option was declared as "filesystem,fs".
That throws invalid_option_name while constructing the
options_description, so the tool aborted on startup. Drop the bogus
short alias.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/tools/cephfs/cephfs-tool.cc | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/tools/cephfs/cephfs-tool.cc b/src/tools/cephfs/cephfs-tool.cc
index afb4c21dd50..3e75f8b782f 100644
--- a/src/tools/cephfs/cephfs-tool.cc
+++ b/src/tools/cephfs/cephfs-tool.cc
@@ -696,7 +696,7 @@ int main(int argc, char **argv) {
     ("conf,c", po::value<string>(&config.ceph_conf), "Ceph config file path")
     ("id,i", po::value<string>(&config.userid)->default_value("admin"), "Client ID")
     ("keyring,k", po::value<string>(&config.keyring), "Path to keyring file")
-    ("filesystem,fs", po::value<string>(&config.filesystem), "CephFS filesystem name to mount")
+    ("filesystem", po::value<string>(&config.filesystem), "CephFS filesystem name to mount")
     ("uid", po::value<int>(&config.uid)->default_value(-1), "User ID to mount as")
     ("gid", po::value<int>(&config.gid)->default_value(-1), "Group ID to mount as");
 
