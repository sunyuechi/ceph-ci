From 7fe75845b4d908fb6d789181559ff3f54397acd3 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Mon, 29 Jun 2026 19:38:18 -0700
Subject: [PATCH 07/13] rgw/es: require both major and minor in ES version
 parsing

parse_version() only treated sscanf() < 0 as failure, but sscanf returns
the count of fields assigned: "7" or a non-numeric string yields 0 or 1
and leaves major/minor uninitialized, polluting later version checks.
Require both fields to be parsed and return EINVAL otherwise.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/rgw/driver/rados/rgw_sync_module_es.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/rgw/driver/rados/rgw_sync_module_es.cc b/src/rgw/driver/rados/rgw_sync_module_es.cc
index 1e1b894efd9..ab97d3449b1 100644
--- a/src/rgw/driver/rados/rgw_sync_module_es.cc
+++ b/src/rgw/driver/rados/rgw_sync_module_es.cc
@@ -136,8 +136,8 @@ struct es_version_decoder {
   int parse_version(const std::string& s) {
     int major, minor;
     int ret = sscanf(s.c_str(), "%d.%d", &major, &minor);
-    if (ret < 0) {
-      return ret;
+    if (ret < 2) {
+      return -EINVAL;
     }
     version = std::make_pair(major,minor);
     return 0;
-- 
2.55.0

