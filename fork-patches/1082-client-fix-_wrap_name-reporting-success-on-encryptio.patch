From 671a307929354b252f4f452e71350332a5175255 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Wed, 1 Jul 2026 01:56:16 -0700
Subject: [PATCH 2/3] client: fix _wrap_name reporting success on encryption
 failure

_wrap_name() returns bool, but the two filename encryption error paths
did "return r" with r < 0. A negative int converts to true, so callers
treated an encryption failure as success and went on to create a dentry
from the unencrypted name. Return false instead, matching the other
error paths in this function.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/client/Client.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/client/Client.cc b/src/client/Client.cc
index 17366b83269..fcac11545e7 100644
--- a/src/client/Client.cc
+++ b/src/client/Client.cc
@@ -1417,7 +1417,7 @@ bool Client::_wrap_name(Inode& diri, std::string& dname, std::string& alternate_
     int r = fscrypt_denc->get_encrypted_fname(dname, &_enc_name, &_alt_name, false);
     if (r < 0) {
       ldout(cct, 0) << __FILE__ << ":" << __LINE__ << ": failed to encrypt filename" << dendl;
-      return r;
+      return false;
     }
     dname = std::move(_enc_name);
     if (alternate_name.empty()) {
@@ -1428,7 +1428,7 @@ bool Client::_wrap_name(Inode& diri, std::string& dname, std::string& alternate_
       int r = fscrypt_denc->get_encrypted_fname(alternate_name, &_enc_name, &_alt_name, true);
       if (r < 0) {
         ldout(cct, 0) << __FILE__ << ":" << __LINE__ << ": failed to encrypt filename" << dendl;
-        return r;
+        return false;
       }
       alternate_name = std::move(_alt_name);
     }
-- 
