From 956f6caa7f990b1848f6834bec9a949b8fa120ad Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Tue, 30 Jun 2026 09:27:16 -0700
Subject: [PATCH] cmake: keep seastar's Seastar_SANITIZE in lockstep with
 WITH_ASAN

Seastar_SANITIZE defaults to ON under a Debug build regardless of
WITH_ASAN, so a WITH_ASAN=OFF build still sanitizes seastar while ceph
keeps tcmalloc, crashing crimson tests before main().

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/CMakeLists.txt | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index c9c7f50934d..1652c9408b9 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -475,6 +475,11 @@ if(WITH_CRIMSON)
   set(Seastar_API_LEVEL "10" CACHE STRING "" FORCE)
   set(Seastar_IO_URING ${HAVE_LIBURING} CACHE BOOL "" FORCE)
   set(Seastar_DEPRECATED_OSTREAM_FORMATTERS OFF CACHE BOOL "" FORCE)
+  if(WITH_ASAN)
+    set(Seastar_SANITIZE ON CACHE STRING "" FORCE)
+  else()
+    set(Seastar_SANITIZE OFF CACHE STRING "" FORCE)
+  endif()
   if(Seastar_DPDK)
     find_package(dpdk QUIET)
     if(NOT DPDK_FOUND)
-- 
2.54.0

