+# Mirrors openRuyi's downstream ceph.spec make_check BuildRequires.
+BuildRequires:  gcc-fortran
+BuildRequires:  pkgconfig(openblas)
+BuildRequires:  rust
+# With CEPH_PYTHON_SYSTEM_SITE set (see src/tools/setup-virtualenv.sh), the test
+# venvs use system site-packages, so these RPMs satisfy test deps instead of pip
+# building them from sdist (e.g. cryptography has no riscv64 wheel).
+# Listed only for deps openRuyi ships at a version the tests accept; the rest
+# still come via pip.
+BuildRequires:  python3dist(cryptography)
+BuildRequires:  python3dist(jsonpatch)
+BuildRequires:  python3dist(jinja2)
+BuildRequires:  python3dist(pyopenssl)
+BuildRequires:  python3dist(werkzeug)
