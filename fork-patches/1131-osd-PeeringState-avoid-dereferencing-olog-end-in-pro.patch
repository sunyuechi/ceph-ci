From f331f856e1f7208120ff8518133276c43da7983f Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Thu, 25 Jun 2026 21:39:11 +0800
Subject: [PATCH 1/3] osd/PeeringState: avoid dereferencing olog end() in
 proc_master_log

op always equals olog.log.end(), so op->version dereferenced the end
iterator (undefined behaviour, present since commit 5f687c4a182b).
Compare the last log entry via std::prev(op) instead.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/osd/PeeringState.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/osd/PeeringState.cc b/src/osd/PeeringState.cc
index c3ed6be8107..65fb1f4b537 100644
--- a/src/osd/PeeringState.cc
+++ b/src/osd/PeeringState.cc
@@ -3432,11 +3432,11 @@ void PeeringState::proc_master_log(
 	} else {
 	  consider_adjusting_pwlc(pg_log.get_tail());
 	}
-      } else if (op->version == p->version) {
+      } else if (std::prev(op)->version == p->version) {
 	// Normal case - both logs have this entry
 	consider_adjusting_pwlc(p->version);
 	++p;
-      } else if (op->version < p->version) {
+      } else if (std::prev(op)->version < p->version) {
 	// Last entry in other log is before this entry
 	consider_adjusting_pwlc(pg_log.get_tail());
       } else {
-- 
