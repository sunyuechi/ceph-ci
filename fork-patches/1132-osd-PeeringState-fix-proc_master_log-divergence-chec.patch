From d48130b9f4c2a290a226d533ee47399d7c67b5b7 Mon Sep 17 00:00:00 2001
From: Sun Yuechi <sunyuechi@iscas.ac.cn>
Date: Sun, 12 Jul 2026 11:25:19 -0700
Subject: [PATCH 2/3] osd/PeeringState: fix proc_master_log divergence check vs
 olog.head

When the last entry of the other log is older than p->version but
p->version <= olog.head (log gaps after a PG split, or apply_pwlc
having advanced olog.head past the last entry), proc_master_log rolled
pwlc back to the log tail instead of winding forward, so acked partial
writes could be misjudged as divergent. Commit 1b44fd9991f5 turned
this case from the normal case into the rollback branch; the
regression was masked by the olog.log.end() dereference fixed in the
previous commit.

Accept p->version <= olog.head like the empty-log branch does, and
replace the never-moved iterator op with olog.log.empty() and
olog.log.back() so an end() dereference cannot be reintroduced.

Signed-off-by: Sun Yuechi <sunyuechi@iscas.ac.cn>
---
 src/osd/PeeringState.cc | 27 +++++++++++++++------------
 1 file changed, 15 insertions(+), 12 deletions(-)

diff --git a/src/osd/PeeringState.cc b/src/osd/PeeringState.cc
index 65fb1f4b537..b47332d3628 100644
--- a/src/osd/PeeringState.cc
+++ b/src/osd/PeeringState.cc
@@ -3423,25 +3423,28 @@ void PeeringState::proc_master_log(
       // of p->version. So long as there are no entries in olog between
       // p->version and olog.head we can still try to wind forward
       // partially written entries
-      auto op = olog.log.end();
-      if (op == olog.log.begin()) {
-	// Other log is emtpy
+      if (olog.log.empty()) {
 	if (p->version <= olog.head) {
 	  consider_adjusting_pwlc(p->version);
 	  ++p;
 	} else {
 	  consider_adjusting_pwlc(pg_log.get_tail());
 	}
-      } else if (std::prev(op)->version == p->version) {
-	// Normal case - both logs have this entry
-	consider_adjusting_pwlc(p->version);
-	++p;
-      } else if (std::prev(op)->version < p->version) {
-	// Last entry in other log is before this entry
-	consider_adjusting_pwlc(pg_log.get_tail());
       } else {
-	// Other log is ahead of the primary log - give up
-	p = pg_log.get_log().log.end();
+	const eversion_t olast = olog.log.back().version;
+	if (olast == p->version ||
+	    (olast < p->version && p->version <= olog.head)) {
+	  // Normal case - both logs have entry p->version, or olog has
+	  // no entries between p->version and olog.head
+	  consider_adjusting_pwlc(p->version);
+	  ++p;
+	} else if (olast < p->version) {
+	  // Divergence is before the oldest entry both logs share
+	  consider_adjusting_pwlc(pg_log.get_tail());
+	} else {
+	  // Other log is ahead of the primary log - give up
+	  p = pg_log.get_log().log.end();
+	}
       }
     }
     // See if we can wind forward partially written entries
